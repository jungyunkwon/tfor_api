@baseUrl = http://localhost:3000
# Supabase JWT 토큰을 여기에 입력하세요
@token = YOUR_SUPABASE_ACCESS_TOKEN

### 1. 내 프로필 조회
GET {{baseUrl}}/profiles/me
Authorization: Bearer {{token}}

### 2. 내 프로필 수정
PUT {{baseUrl}}/profiles/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "data": {
        "nickname": "테스트유저",
        "gender": "M",
        "birth_year": 1990,
        "height_cm": 180,
        "region_code": "02"
    }
}
